<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/rootScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="24dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HUMHUM"
                android:textColor="@color/ink"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxWidth="140dp"
                android:singleLine="true"
                android:text="等待连接"
                android:textColor="@color/muted"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/connectPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/connectMascot"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:src="@drawable/mascot_humi" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="连接这台电脑"
                        android:textColor="@color/ink"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="在 Hexa 中开启移动访问并生成配对码。"
                        android:textColor="@color/muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/scanSetupButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/primary"
                android:text="扫描电脑配对二维码"
                android:textAllCaps="false"
                android:textColor="@color/surface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/scanPairingStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/role_hero_background"
                android:gravity="center"
                android:padding="16dp"
                android:text="二维码已识别\n正在通过加密中继连接这台电脑"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/manualPairingToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_secondary"
                android:text="使用手动配对"
                android:textAllCaps="false"
                android:textColor="@color/primary" />

            <LinearLayout
                android:id="@+id/manualPairingPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/pasteSetupButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/button_secondary"
                    android:text="粘贴配对资料"
                    android:textAllCaps="false"
                    android:textColor="@color/primary" />

                <EditText
                    android:id="@+id/urlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="50dp"
                    android:layout_marginTop="10dp"
                    android:autofillHints=""
                    android:background="@drawable/input_background"
                    android:hint="https://192.168.x.x:31276"
                    android:inputType="textUri"
                    android:singleLine="true"
                    android:textColor="@color/ink"
                    android:textColorHint="#93A4B8" />

                <EditText
                    android:id="@+id/codeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/input_background"
                    android:hint="8 位配对码"
                    android:inputType="textCapCharacters"
                    android:maxLength="8"
                    android:singleLine="true"
                    android:textColor="@color/ink"
                    android:textColorHint="#93A4B8" />

                <EditText
                    android:id="@+id/fingerprintInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="72dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/input_background"
                    android:gravity="top"
                    android:hint="TLS SHA-256 指纹"
                    android:inputType="textNoSuggestions"
                    android:maxLength="95"
                    android:textColor="@color/ink"
                    android:textColorHint="#93A4B8"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/deviceNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/input_background"
                    android:hint="设备名称（例如 Xiaomi 14）"
                    android:inputType="textCapWords"
                    android:maxLength="80"
                    android:singleLine="true"
                    android:textColor="@color/ink"
                    android:textColorHint="#93A4B8" />

                <Button
                    android:id="@+id/connectButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@color/primary"
                    android:text="安全配对"
                    android:textAllCaps="false"
                    android:textColor="@color/surface"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/connectError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#C2413B"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sessionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/scopeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/muted"
                android:textSize="11sp" />

                <Button
                    android:id="@+id/refreshButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="42dp"
                    android:background="@drawable/button_secondary"
                    android:text="刷新"
                    android:textAllCaps="false"
                    android:textColor="@color/primary" />

                <Button
                    android:id="@+id/disconnectButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="42dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/button_secondary"
                    android:text="断开"
                    android:textAllCaps="false"
                    android:textColor="#9A4C45" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/roleHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/role_hero_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageView
                    android:id="@+id/roleHeroMascot"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:src="@drawable/mascot_humi" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/roleKicker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HUMI · 今天"
                        android:textColor="@color/humi_accent"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/roleTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="我替你留意今天的重要进展"
                        android:textColor="@color/ink"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/roleDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="先解释与你有关的事，再给出一个小而有用的下一步。"
                        android:textColor="@color/muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/roleContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />

            <LinearLayout
                android:id="@+id/hexaDetailContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <LinearLayout
                android:id="@+id/sessionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="后台监控"
                        android:textColor="@color/ink"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/monitorStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已关闭"
                        android:textColor="@color/muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <Switch
                    android:id="@+id/monitorSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:contentDescription="后台监控" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/panel_background"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="后台可靠性"
                        android:textColor="@color/ink"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/batteryStatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:textColor="@color/muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/pushStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="系统推送尚未配置"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="42dp"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/batterySettingsButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="42dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_secondary"
                        android:text="电池设置"
                        android:textAllCaps="false"
                        android:textColor="@color/primary" />

                    <Button
                        android:id="@+id/autostartSettingsButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="42dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_secondary"
                        android:text="自启动设置"
                        android:textAllCaps="false"
                        android:textColor="@color/primary"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/roleNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/role_nav_background"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/humiTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:background="@drawable/role_tab_selected"
            android:clickable="true"
            android:contentDescription="@string/role_humi"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/humiTabMascot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:src="@drawable/mascot_humi" />

            <TextView
                android:id="@+id/humiTabLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Humi"
                android:textColor="@color/humi_accent"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hypeTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:background="@drawable/role_tab_idle"
            android:clickable="true"
            android:contentDescription="@string/role_hype"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/hypeTabMascot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:src="@drawable/mascot_hype" />

            <TextView
                android:id="@+id/hypeTabLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hype"
                android:textColor="@color/muted"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hushTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:background="@drawable/role_tab_idle"
            android:clickable="true"
            android:contentDescription="@string/role_hush"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/hushTabMascot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:src="@drawable/mascot_hush" />

            <TextView
                android:id="@+id/hushTabLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hush"
                android:textColor="@color/muted"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hexaTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:background="@drawable/role_tab_idle"
            android:clickable="true"
            android:contentDescription="@string/role_hexa"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/hexaTabMascot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:src="@drawable/mascot_hexa" />

            <TextView
                android:id="@+id/hexaTabLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hexa"
                android:textColor="@color/muted"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
