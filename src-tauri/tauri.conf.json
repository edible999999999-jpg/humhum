{
  "productName": "DevPod",
  "version": "0.1.0",
  "identifier": "com.devpod.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "DevPod",
        "width": 280,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "backgroundColor": [0, 0, 0, 0],
        "skipTaskbar": true,
        "resizable": false,
        "focus": true,
        "visible": true,
        "shadow": false,
        "dragDropEnabled": false,
        "url": "index.html"
      },
      {
        "label": "settings",
        "title": "DevPod Settings",
        "width": 420,
        "height": 620,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true,
        "focus": true,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; media-src 'self' blob: asset: https://asset.localhost; connect-src 'self' http://localhost:* https:; script-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "id": "devpod-tray"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
